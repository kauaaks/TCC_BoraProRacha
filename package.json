{
  "name": "tcc_borapro",
  "version": "1.0.0",
  "private": true,
  "scripts": {
  "bootstrap": "npm-run-all -p bootstrap:*",
  "bootstrap:root": "npm ci || npm i",
  "bootstrap:front": "cd front && (npm ci || npm i)",
  "bootstrap:backend": "cd backend && (npm ci || npm i)",
  "dev:front": "npm run dev --prefix front",
  "dev:back": "npm run dev --prefix backend",
  "wait:front": "wait-on http://localhost:5173",
  "dev:front:first": "npm-run-all dev:front",
  "dev:back:after-front": "npm-run-all wait:front dev:back",
  "dev": "concurrently -n FRONT,BACK -c green,cyan \"npm run dev:front:first\" \"npm run dev:back:after-front\"",
  "start:all": "npm-run-all bootstrap dev",
  "clean": "rimraf front/node_modules backend/node_modules front/package-lock.json backend/package-lock.json package-lock.json",

  "docker:init": "docker compose run --rm app sh -c \"npm install && npm run bootstrap\" && docker compose up",
  "docker:dev": "docker compose up"
},
  "devDependencies": {
    "concurrently": "^9.2.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "qrcode": "^1.5.4",
    "react-chartjs-2": "^5.3.1",
    "react-icons": "^5.5.0"
  }
}
